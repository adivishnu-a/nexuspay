# Database (Neon: same DB used locally and by Render)
SPRING_DATASOURCE_URL=jdbc:postgresql://ep-xxx.us-east-1.aws.neon.tech/nexuspay?sslmode=require
SPRING_DATASOURCE_USERNAME=nexuspay
SPRING_DATASOURCE_PASSWORD=xxxxxxxx

# JWT (generate with `openssl rand -base64 32`)
JWT_SECRET=replace-me-with-256-bit-base64-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# Google OAuth
GOOGLE_CLIENT_ID=xxxxxx.apps.googleusercontent.com

# CORS (locally just the localhost origins; on Render, set to the Vercel URLs)
NEXUSPAY_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Cookie Secure flag: false locally (HTTP), true on Render (HTTPS)
COOKIE_SECURE=false

# Logging
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_NEXUSPAY=INFO
